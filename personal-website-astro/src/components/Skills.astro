---
export interface Props {
  t: {
    label: string;
    title: string;
    groups: {
      name: string;
      tags: string[];
    }[];
  };
}

const { t } = Astro.props;
---

<section id="skills">
  <div class="container">
    <p class="section-label" data-animate>{t.label}</p>
    <h2 class="section-title" data-animate>{t.title}</h2>
    {t.groups.map((group) => (
      <div class="skill-group" data-animate>
        <p class="skill-group-name">{group.name}</p>
        <div class="skill-tags">
          {group.tags.map((tag) => <span class="skill-tag" data-stagger>{tag}</span>)}
        </div>
      </div>
    ))}
  </div>
</section>
