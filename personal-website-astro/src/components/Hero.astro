---
export interface Props {
  t: {
    name: string;
    subtitle: string;
    tagline: string;
    cta: string;
  };
}

const { t } = Astro.props;
---

<section class="hero">
  <div class="hero-overlay"></div>
  <h1>{t.name}</h1>
  <p class="hero-subtitle">{t.subtitle}</p>
  <p class="hero-tagline">{t.tagline}</p>
  <a href="#contact" class="hero-cta">{t.cta}</a>
  <div class="hero-scroll-indicator">
    <div class="mouse"></div>
  </div>
</section>
