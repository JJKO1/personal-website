---
export interface Props {
  t: {
    label: string;
    title: string;
    role: string;
    date: string;
    company: string;
    bullets: string[];
  };
}

const { t } = Astro.props;
---

<section id="experience">
  <div class="container">
    <p class="section-label">{t.label}</p>
    <h2 class="section-title">{t.title}</h2>
    <div class="timeline">
      <div class="timeline-item">
        <div class="timeline-header">
          <span class="timeline-role">{t.role}</span>
          <span class="timeline-date">{t.date}</span>
        </div>
        <div class="timeline-company">{t.company}</div>
        <ul class="timeline-desc">
          {t.bullets.map((b) => <li>{b}</li>)}
        </ul>
      </div>
    </div>
  </div>
</section>
