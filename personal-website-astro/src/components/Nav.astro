---
export interface Props {
  lang: 'en' | 'zh';
}

const { lang } = Astro.props;
const otherLang = lang === 'en' ? 'zh' : 'en';
const otherLabel = lang === 'en' ? '中文' : 'EN';

const navItems = [
  { key: 'about', label: lang === 'en' ? 'About' : '关于' },
  { key: 'experience', label: lang === 'en' ? 'Experience' : '经历' },
  { key: 'projects', label: lang === 'en' ? 'Projects' : '项目' },
  { key: 'skills', label: lang === 'en' ? 'Skills' : '技能' },
  { key: 'contact', label: lang === 'en' ? 'Contact' : '联系' },
];
---

<nav class="nav">
  <div class="nav-inner">
    <a class="nav-logo" href={`/personal-website/${lang}/`}>Jonah</a>
    <ul class="nav-links">
      {navItems.map((item) => (
        <li>
          <a href={`#${item.key}`}>{item.label}</a>
        </li>
      ))}
      <li>
        <a class="lang-link" href={`/personal-website/${otherLang}/`}>
          {otherLabel}
        </a>
      </li>
    </ul>
  </div>
</nav>
